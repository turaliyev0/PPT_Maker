# ── Dependencies ───────────────────────────────────────────────
node_modules/

# ── Python cache ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Generated / intermediate artifacts ─────────────────────────
# Extracted HWP content (rebuilt on every run)
templates/extracted/

# Pipeline outputs (rebuilt on every run)
slides/
presentation.pptx
qa_screenshots/
*.hwp

# Visual QA screenshots (legacy path)
qa/

# Generated guide PDF (source: guide/guide.html)
guide/guide.pdf

# Temporary Office lock files
~$*.pptx
~$*.hwp

# ── Filtered-out source images (auto-sorted by extract script) ──
presentation_1-images/_removed/

# ── User-provided images (contents gitignored; folder tracked via README) ──
preloadable_images/*
!preloadable_images/README.md
